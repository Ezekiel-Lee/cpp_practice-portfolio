#include <iostream>
#include <vector>

class Calculator {
private:
    std::vector<int> numbers;

public:
    void input() {
        int num;

        std::cout << "Enter numbers (-1 to stop): ";

        while (std::cin >> num && num != -1) {
            numbers.push_back(num);
        }
    }

    int sum() {
        int total = 0;

        for (int i = 0; i < numbers.size(); i++) {
            total += numbers[i];
        }

        return total;
    }

    double average() {
        if (numbers.empty()) return 0;

        return (double)sum() / numbers.size();
    }

    void display() {
        std::cout << "Numbers: ";

        for (int i = 0; i < numbers.size(); i++) {
            std::cout << numbers[i] << " ";
        }

        std::cout << std::endl;
    }
};

int main() {
    Calculator calc;

    calc.input();
    calc.display();

    std::cout << "Sum: " << calc.sum() << std::endl;
    std::cout << "Average: " << calc.average() << std::endl;

    return 0;
}