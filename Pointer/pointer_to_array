#include <iostream>
using namespace std;

void pointer_to_array(int* arr, int size) {
    int* ptr = arr;

    cout << "The elements in the array are: ";

    for (int i = 0; i < size; i++) {
        cout << *ptr << " ";
        ptr++; // move pointer
    }

    cout << endl;
}

int main() {
    int arr[] = {1, 2, 3, 4, 5};
    int size = 5;

    pointer_to_array(arr, size);

    return 0;
}