#include<iostream>
#include<vector>
int main(){
    std::vector<int> a;
    int n, sum = 0;
    std::cout << "enter numbers, and 0 to stop: " << std::endl;

    while(true){ // infinite loop until user enters 0
        std::cin >> n;
        if(n == 0){
            break;
        }
        a.push_back(n);
        sum += n;
    }
    if(!a.empty()){ // prevent division by zero
        double average = (double)sum / a.size();
        std::cout << "The average value in the array is: " << average << std::endl;
    } else {
        std::cout << "No numbers were entered." << std::endl;
    }
}