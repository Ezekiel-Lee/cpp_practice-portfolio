#include<iostream>

int square(int x) {
    return x * x;
}

int main() {
    int num;
    std:: cout << "enter an integer: ";
    std:: cin >> num;
    int result = square(num);
    std:: cout << "The square of " << num << " is: " << result << std::endl;
    return 0;

}