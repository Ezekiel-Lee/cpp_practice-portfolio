#include<iostream>

int max(int a, int b) {
    return (a > b) ? a : b;
}

int main() {
    int num1, num2, num3;
    std:: cout << "Enter three numbers: ";
    std:: cin >> num1 >> num2 >> num3;
    int result = max(max(num1, num2), num3);
    std:: cout << "The maximum of " << num1 << ", " << num2 << ", and " << num3 << " is: " << result << std::endl;
    return 0;
}