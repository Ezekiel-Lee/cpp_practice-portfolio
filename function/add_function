#include<iostream>

int add(int a, int b) {
    return a + b;
}

int main() {
    int num1, num2;
    std:: cout << "Enter two numbers: ";
    std:: cin >> num1 >> num2;
    int result = add(num1, num2);
    std:: cout << "The sum of " << num1 << " and " << num2 << " is: " << result << std::endl;
    return 0;
}