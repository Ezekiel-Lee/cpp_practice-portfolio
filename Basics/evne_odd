#include<iostream>

int main() {
    int a;
    std::cout << "Enter a number: " << std::endl;
    std::cin >> a;
    if (a % 2 == 0) {
        std::cout << a << " is an even number." << std::endl;
    } else {
        std::cout << a << " is an odd number." << std::endl;   
    }
    return 0;    
}